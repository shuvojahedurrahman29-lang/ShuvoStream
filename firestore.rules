rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny for safety
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow connection test check
    match /test/{docId} {
      allow read: if true;
    }

    // Allow full read and write access to channels, banners, and notifications
    // to enable successful admin management (upload, edit, and delete) 
    // even when using the secure passcode login fallback under browser iframe constraints.
    match /channels/{channelId} {
      allow read, write: if true;
    }

    match /banners/{bannerId} {
      allow read, write: if true;
    }

    match /notifications/{notificationId} {
      allow read, write: if true;
    }
  }
}
